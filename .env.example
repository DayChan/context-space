# Canonical Markdown workspace. Relative paths resolve from the project root.
CONTEXT_SPACE_ROOT=./workspace

# The API binds to loopback by default.
CONTEXT_SPACE_HOST=127.0.0.1
CONTEXT_SPACE_PORT=4318

# Lark sync defaults. V1 uses read-only lark-cli commands with user identity.
CONTEXT_SPACE_BACKFILL_DAYS=30
CONTEXT_SPACE_OVERLAP_MINUTES=10

# 可选：部署级锁定 LLM 分析方式。未设置时读取 workspace/config/analysis.md。
# 支持 codex-sdk 或 codex-exec。凭证不得写入本文件或 Markdown 工作区。
# CONTEXT_SPACE_ANALYSIS_PROVIDER=codex-sdk

# 结构化日志。默认输出终端并写入 <workspace>/.context/logs/。
CONTEXT_SPACE_LOG_LEVEL=info
CONTEXT_SPACE_LOG_CONSOLE=true
CONTEXT_SPACE_LOG_FILE=true
# CONTEXT_SPACE_LOG_DIR=./workspace/.context/logs
CONTEXT_SPACE_LOG_MAX_BYTES=10485760
CONTEXT_SPACE_LOG_RETENTION_DAYS=14
